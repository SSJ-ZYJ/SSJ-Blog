---
import path from "node:path";

interface Props {
	id?: string;
	src: string;
	class?: string;
	alt?: string;
	position?: string;
	basePath?: string;
}

import { Image } from "astro:assets";
import { url } from "../../utils/url-utils";

const { id, src, alt, position = "center", basePath = "/" } = Astro.props;
const className = Astro.props.class;

const isLocal = !(
	src.startsWith("/") ||
	src.startsWith("http") ||
	src.startsWith("https") ||
	src.startsWith("data:")
);
const isPublic = src.startsWith("/");

let img: ImageMetadata | undefined;
if (isLocal) {
	const files = import.meta.glob<ImageMetadata>("src/**", {
		import: "default",
		eager: false,
	});
	const normalizedSrc = src.replace(/^\.\//, "").replace(/^\//, "");
	const normalizedBasePath = basePath.replace(/^\.\//, "").replace(/^\//, "");
	const normalizedPath = path
		.normalize(path.join("src/", normalizedBasePath, normalizedSrc))
		.replace(/\\/g, "/");

	const file = files[`/${normalizedPath}`];
	if (!file) {
		const lowerPath = `/${normalizedPath}`.toLowerCase();
		for (const [key, value] of Object.entries(files)) {
			if (key.toLowerCase() === lowerPath) {
				img = (await value()) as ImageMetadata;
				break;
			}
		}
		if (!img) {
			console.error(`\n[ERROR] Image file not found: /${normalizedPath}`);
		}
	} else {
		img = (await file()) as ImageMetadata;
	}
}

const imageClass = "w-full h-full object-cover";
const imageStyle = `object-position: ${position}`;
---
<div id={id} class:list={[className, 'overflow-hidden relative']}>
    <div class="transition absolute inset-0 dark:bg-black/10 bg-opacity-50 pointer-events-none"></div>
    {isLocal && img && <Image src={img} alt={alt || ""} class={imageClass} style={imageStyle}/>}
    {!isLocal && <img src={isPublic ? url(src) : src} alt={alt || ""} class={imageClass} style={imageStyle}/>}
</div>
